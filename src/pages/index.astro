---
import BaseLayout from '../layouts/BaseLayout.astro';
import { client } from '../lib/microcms';
import type { Post } from '../lib/microcms';

const { contents: posts } = await client.getList<Post>({
  endpoint: 'posts',
  queries: { orders: '-publishedAt', limit: 20 },
});
---

<BaseLayout>
  <ul class="divide-y divide-[#e8e6e1]">
    {posts.map((post) => {
      const category = Array.isArray(post.category) ? post.category[0] : post.category;
      return (
        <li>
          <a href={`/posts/${post.slug}`} class="block py-8 group">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-xs text-[#bbb]">{post.publishedAt.slice(0, 10)}</span>
              <span class="text-xs text-[#999] border border-[#e0ddd8] rounded px-1.5 py-0.5">{category}</span>
            </div>
            <h2 class="text-base font-medium leading-relaxed group-hover:opacity-50 transition-opacity">
              {post.title}
            </h2>
            {post.description && (
              <p class="mt-1.5 text-sm text-[#999] leading-relaxed">{post.description}</p>
            )}
          </a>
        </li>
      );
    })}
  </ul>
</BaseLayout>

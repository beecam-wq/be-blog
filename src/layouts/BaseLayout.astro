---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const { title, description, ogImage, ogType = 'website' } = Astro.props;
const pageTitle = title ? `${title} — be-blog` : 'be-blog';
const desc = description ?? 'デザイン・写真・絵本・映画など、気になることを気軽に書いていく場所。';

const categories = [
  { label: 'design', href: '/design' },
  { label: 'photo', href: '/photo' },
  { label: 'book', href: '/book' },
  { label: 'film', href: '/film' },
  { label: 'note', href: '/note' },
];
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={Astro.url.href} />

    <!-- OGP -->
    <meta property="og:site_name" content="be-blog" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={Astro.url.href} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={desc} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#fafaf8] text-[#1c1c1c] font-sans antialiased min-h-screen flex flex-col">
    <header class="border-b border-[#e8e6e1]">
      <div class="max-w-[680px] mx-auto px-6 py-5 flex items-center justify-between">
        <a href="/" class="text-sm font-medium tracking-wide hover:opacity-60 transition-opacity">
          be-blog
        </a>
        <nav class="flex gap-5">
          {categories.map((cat) => (
            <a
              href={cat.href}
              class="text-xs text-[#999] hover:text-[#1c1c1c] transition-colors tracking-wide"
            >
              {cat.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="flex-1 max-w-[680px] mx-auto w-full px-6 py-14">
      <slot />
    </main>

    <footer class="border-t border-[#e8e6e1]">
      <div class="max-w-[680px] mx-auto px-6 py-6 text-xs text-[#bbb]">
        © 2026 Yasuhide Ura
      </div>
    </footer>
  </body>
</html>
